#ifndef QTCHOOSER_QTCHOOSER_CONFIG_H
#define QTCHOOSER_QTCHOOSER_CONFIG_H

namespace qtchooser::config {
    // Project info
    const auto kProjectName = "${PROJECT_NAME}";
    const auto kProjectDisplayName = "${PROJECT_DISPLAY_NAME}";
    const auto kProjectVersion = "${PROJECT_VERSION}";
    const auto kProjectVersionMajor = ${PROJECT_VERSION_MAJOR}u;
    const auto kProjectVersionMinor = ${PROJECT_VERSION_MINOR}u;
    const auto kProjectVersionPatch = ${PROJECT_VERSION_PATCH}u;
    const auto kProjectBuildTimestamp = ${PROJECT_BUILD_TIMESTAMP}u;
    const auto kProjectCommitSha = "${PROJECT_COMMIT_SHA}";
    const auto kProjectDescription = "${PROJECT_DESCRIPTION}";
    const auto kProjectHomepageUrl = "${PROJECT_HOMEPAGE_URL}";
    const auto kProjectOrganizationName = "${PROJECT_ORGANIZATION_NAME}";
    const auto kProjectOrganizationDomain = "${PROJECT_ORGANIZATION_DOMAIN}";
    const auto kProjectAuthor = "${PROJECT_AUTHOR}";
}

#endif //QTCHOOSER_QTCHOOSER_CONFIG_H
